        { q: "Wie lautet die erste binomische Formel?", a: ["(a+b)² = a² + b²", "(a+b)² = a² + 2ab + b²", "(a-b)² = a² - 2ab + b²", "(a+b)(a-b) = a² - b²"], c: "(a+b)² = a² + 2ab + b²" },
