        { q: "Eine Leiter ist 5m lang und steht 3m von einer Wand entfernt. Wie hoch reicht sie an der Wand (Pythagoras)?", a: ["2 m", "4 m", "4.5 m", "16 m"], c: "4 m" },
        { q: "Welche Seite ist in einem rechtwinkligen Dreieck immer die längste?", a: ["Ankathete", "Gegenkathete", "Hypotenuse", "Basis"], c: "Hypotenuse" },
