        { q: "Wie lautet die Normalform einer quadratischen Funktion?", a: ["f(x) = mx + b", "f(x) = ax² + bx + c", "f(x) = a(x-d)² + e", "f(x) = x³"], c: "f(x) = ax² + bx + c" }
