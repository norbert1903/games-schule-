        { q: "Wohin ist die Parabel f(x) = x² − 4 verschoben?", a: ["4 Einheiten nach links", "4 Einheiten nach rechts", "4 Einheiten nach oben", "4 Einheiten nach unten"], c: "4 Einheiten nach unten" },
