        { q: "Wie nennt man ein Dreieck, bei dem zwei Seiten gleich lang sind?", a: ["Gleichseitiges Dreieck", "Gleichschenkliges Dreieck", "Unregelmäßiges Dreieck", "Rechtwinkliges Dreieck"], c: "Gleichschenkliges Dreieck" },
